# Example Environment Configuration for Darkspace Tools
#
# Copy this file to .env and customize with your values.
# Or run `scripts/setup.sh` to generate it interactively.
#
# IP addresses below are RFC 5737 examples. Replace with your actual IPs.

# Deployment Profile: netflow | ids | honeypot-lite | honeypot-full
DARKSPACE_PROFILE=netflow

# Services (for honeypot-lite only, comma-separated)
# Options: cowrie,dionaea,honeytrap,mailoney,suricata
DARKSPACE_SERVICES=all

# Network Configuration (CHANGE THESE)
TARGET_IP=198.51.100.50          # Target IP for honeypot/monitoring traffic
DARKSPACE_IP=203.0.113.10        # Remote GRE tunnel endpoint
GRE_LOCAL_IP=192.168.240.1       # Local GRE tunnel IP
GRE_INTERFACE=darkspace-gre      # GRE interface name

# Cloud Provider
VPC_REGION=tor1                   # DigitalOcean region

# T-Pot Configuration (honeypot-lite / honeypot-full only)
TPOT_VERSION=24.04.1
TPOT_USER=honeypot
TPOT_WEB_PORT=64297

# Docker
COMPOSE_PROJECT_NAME=tpotce
TPOT_PULL_POLICY=if_not_present
