#!/bin/bash
# Darkspace Tools - Honeypot Monitoring Script
# Generated by Ansible
# Target IP: {{ target_ip }}
# Management IP: {{ ansible_default_ipv4.address }}

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${BLUE}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} $1"; }
success() { echo -e "${GREEN}[OK]${NC} $1"; }
warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[FAIL]${NC} $1"; }

echo "=== Darkspace Tools - Sensor Monitoring ==="
echo "Target IP: {{ target_ip }}"
echo "Management IP: {{ ansible_default_ipv4.address }}"
echo "Host: {{ ansible_hostname }}"
echo "Timestamp: $(date)"
echo ""

# Check service status
log "Checking service status..."
if systemctl is-active --quiet tpot; then
    success "Honeypot service is running"
else
    error "Honeypot service is not running"
    systemctl status tpot --no-pager -l | head -5
fi
echo ""

# Check Docker containers
log "Checking containers..."
RUNNING=$(docker ps --filter "status=running" --quiet 2>/dev/null | wc -l)
TOTAL=$(docker ps -a --quiet 2>/dev/null | wc -l)

if [[ $RUNNING -gt 0 ]]; then
    success "$RUNNING/$TOTAL containers running"
    docker ps --format "table {{ '{{' }}.Names{{ '}}' }}\t{{ '{{' }}.Status{{ '}}' }}\t{{ '{{' }}.Ports{{ '}}' }}" 2>/dev/null | head -15
else
    warning "No containers running"
fi
echo ""

# Check target IP binding
log "Checking target IP binding..."
TARGET_LISTENERS=$(ss -tlnp 2>/dev/null | grep "{{ target_ip }}" | wc -l)
if [[ $TARGET_LISTENERS -gt 0 ]]; then
    success "$TARGET_LISTENERS services on target IP {{ target_ip }}"
else
    warning "No services on target IP"
fi
echo ""

# Check disk usage
log "Checking disk usage..."
DISK_USAGE=$(df -h / | tail -1 | awk '{print $5}' | tr -d '%')
if [[ $DISK_USAGE -gt 90 ]]; then
    error "Disk usage critical: ${DISK_USAGE}%"
elif [[ $DISK_USAGE -gt 80 ]]; then
    warning "Disk usage high: ${DISK_USAGE}%"
else
    success "Disk usage: ${DISK_USAGE}%"
fi

# Check memory
log "Checking memory..."
MEM_USAGE=$(free | grep Mem | awk '{printf "%.0f", $3/$2 * 100}')
if [[ $MEM_USAGE -gt 90 ]]; then
    error "Memory usage critical: ${MEM_USAGE}%"
elif [[ $MEM_USAGE -gt 80 ]]; then
    warning "Memory usage high: ${MEM_USAGE}%"
else
    success "Memory usage: ${MEM_USAGE}%"
fi
echo ""

# Check recent errors
log "Checking recent errors..."
ERROR_COUNT=$(journalctl -u tpot --since "1 hour ago" --priority=err --no-pager 2>/dev/null | wc -l)
if [[ $ERROR_COUNT -gt 0 ]]; then
    warning "$ERROR_COUNT errors in last hour"
    journalctl -u tpot --since "1 hour ago" --priority=err --no-pager 2>/dev/null | tail -3
else
    success "No errors in last hour"
fi
