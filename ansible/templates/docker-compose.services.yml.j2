# Lightweight Docker Compose - Individual Services
# Generated by Ansible - Darkspace Tools
# For ids and honeypot-lite profiles (no ELK stack)
# Target IP: {{ target_ip }}

services:
{% if 'suricata' in services or services == 'all' or profile == 'ids' %}
  # Suricata IDS (passive monitoring)
  suricata:
    container_name: suricata
    image: dtagdevsec/suricata:{{ tpot_version }}
    restart: unless-stopped
    network_mode: host
    volumes:
      - suricata_data:/var/log/suricata
      - suricata_rules:/etc/suricata/rules
    environment:
      - SURICATA_INTERFACE=dummy0
      - SURICATA_HOME_NET={{ target_ip }}/32
{% endif %}

{% if 'cowrie' in services %}
  # Cowrie SSH/Telnet Honeypot
  cowrie:
    container_name: cowrie
    image: dtagdevsec/cowrie:{{ tpot_version }}
    restart: unless-stopped
    ports:
      - "{{ target_ip }}:22:2222"
      - "{{ target_ip }}:23:2223"
    volumes:
      - cowrie_data:/cowrie/cowrie-git/var
      - cowrie_keys:/cowrie/cowrie-git/etc
    environment:
      - COWRIE_HOSTNAME=sensor01
{% endif %}

{% if 'dionaea' in services %}
  # Dionaea Multi-Protocol Honeypot
  dionaea:
    container_name: dionaea
    image: dtagdevsec/dionaea:{{ tpot_version }}
    restart: unless-stopped
    ports:
      - "{{ target_ip }}:21:21"
      - "{{ target_ip }}:80:80"
      - "{{ target_ip }}:135:135"
      - "{{ target_ip }}:443:443"
      - "{{ target_ip }}:445:445"
      - "{{ target_ip }}:1433:1433"
      - "{{ target_ip }}:3306:3306"
      - "{{ target_ip }}:5432:5432"
      - "{{ target_ip }}:6379:6379"
      - "{{ target_ip }}:27017:27017"
    volumes:
      - dionaea_data:/opt/dionaea/var
{% endif %}

{% if 'honeytrap' in services %}
  # Honeytrap Email Protocol Honeypot
  honeytrap:
    container_name: honeytrap
    image: dtagdevsec/honeytrap:{{ tpot_version }}
    restart: unless-stopped
    ports:
      - "{{ target_ip }}:110:8110"
      - "{{ target_ip }}:143:8143"
      - "{{ target_ip }}:993:8993"
      - "{{ target_ip }}:995:8995"
    volumes:
      - honeytrap_data:/opt/honeytrap/data
{% endif %}

{% if 'mailoney' in services %}
  # Mailoney SMTP Honeypot
  mailoney:
    container_name: mailoney
    image: dtagdevsec/mailoney:{{ tpot_version }}
    restart: unless-stopped
    ports:
      - "{{ target_ip }}:25:2525"
    volumes:
      - mailoney_data:/opt/mailoney/logs
{% endif %}

volumes:
{% if 'suricata' in services or services == 'all' or profile == 'ids' %}
  suricata_data:
  suricata_rules:
{% endif %}
{% if 'cowrie' in services %}
  cowrie_data:
  cowrie_keys:
{% endif %}
{% if 'dionaea' in services %}
  dionaea_data:
{% endif %}
{% if 'honeytrap' in services %}
  honeytrap_data:
{% endif %}
{% if 'mailoney' in services %}
  mailoney_data:
{% endif %}
