# T-Pot Docker Compose - Full Deployment
# Generated by Ansible - Darkspace Tools
# Honeypot services bind to target IP: {{ target_ip }}
# Management services bind to VPC IP: {{ ansible_default_ipv4.address }}

services:
  # === HONEYPOT SERVICES (target IP) ===

  # Cowrie SSH/Telnet Honeypot
  cowrie:
    container_name: cowrie
    image: dtagdevsec/cowrie:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ target_ip }}:22:2222"
      - "{{ target_ip }}:23:2223"
    volumes:
      - cowrie_data:/cowrie/cowrie-git/var
      - cowrie_keys:/cowrie/cowrie-git/etc
    environment:
      - COWRIE_HOSTNAME=sensor01
    depends_on:
      - elasticsearch

  # Dionaea Multi-Protocol Honeypot
  dionaea:
    container_name: dionaea
    image: dtagdevsec/dionaea:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ target_ip }}:21:21"
      - "{{ target_ip }}:42:42"
      - "{{ target_ip }}:80:80"
      - "{{ target_ip }}:135:135"
      - "{{ target_ip }}:443:443"
      - "{{ target_ip }}:445:445"
      - "{{ target_ip }}:1433:1433"
      - "{{ target_ip }}:1723:1723"
      - "{{ target_ip }}:1883:1883"
      - "{{ target_ip }}:3306:3306"
      - "{{ target_ip }}:5060:5060/udp"
      - "{{ target_ip }}:5432:5432"
      - "{{ target_ip }}:6379:6379"
      - "{{ target_ip }}:11211:11211"
      - "{{ target_ip }}:27017:27017"
    volumes:
      - dionaea_data:/opt/dionaea/var
    depends_on:
      - elasticsearch

  # Honeytrap Email Protocol Honeypot
  honeytrap:
    container_name: honeytrap
    image: dtagdevsec/honeytrap:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ target_ip }}:110:8110"
      - "{{ target_ip }}:143:8143"
      - "{{ target_ip }}:993:8993"
      - "{{ target_ip }}:995:8995"
    volumes:
      - honeytrap_data:/opt/honeytrap/data
    depends_on:
      - elasticsearch

  # Mailoney SMTP Honeypot
  mailoney:
    container_name: mailoney
    image: dtagdevsec/mailoney:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ target_ip }}:25:2525"
    volumes:
      - mailoney_data:/opt/mailoney/logs
    depends_on:
      - elasticsearch

  # Suricata IDS (passive monitoring)
  suricata:
    container_name: suricata
    image: dtagdevsec/suricata:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    volumes:
      - suricata_data:/var/log/suricata
      - suricata_rules:/etc/suricata/rules
    environment:
      - SURICATA_INTERFACE=eth0
      - SURICATA_HOME_NET={{ target_ip }}/32
    depends_on:
      - elasticsearch

  # === MANAGEMENT SERVICES (management/VPC IP) ===

  # Elasticsearch
  elasticsearch:
    container_name: elasticsearch
    image: docker.elastic.co/elasticsearch/elasticsearch:8.15.3
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ ansible_default_ipv4.address }}:9200:9200"
    environment:
      - discovery.type=single-node
      - "ES_JAVA_OPTS=-Xms1g -Xmx1g"
      - xpack.security.enabled=true
      - xpack.security.enrollment.enabled=true
      - ELASTIC_PASSWORD=${ELASTIC_PASSWORD}
      - xpack.security.http.ssl.enabled=true
      - xpack.security.http.ssl.keystore.path=/usr/share/elasticsearch/config/certs/http.p12
      - xpack.security.transport.ssl.enabled=true
      - xpack.security.transport.ssl.keystore.path=/usr/share/elasticsearch/config/certs/transport.p12
    volumes:
      - elasticsearch_data:/usr/share/elasticsearch/data
      - elasticsearch_certs:/usr/share/elasticsearch/config/certs
    ulimits:
      memlock:
        soft: -1
        hard: -1
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE

  # Kibana
  kibana:
    container_name: kibana
    image: docker.elastic.co/kibana/kibana:8.15.3
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ ansible_default_ipv4.address }}:5601:5601"
    environment:
      - ELASTICSEARCH_HOSTS=https://elasticsearch:9200
      - ELASTICSEARCH_USERNAME=elastic
      - ELASTICSEARCH_PASSWORD=${ELASTIC_PASSWORD}
      - ELASTICSEARCH_SSL_CERTIFICATEAUTHORITIES=/usr/share/kibana/config/certs/ca.crt
      - SERVER_HOST=0.0.0.0
      - SERVER_NAME=kibana
      - XPACK_SECURITY_ENABLED=true
    depends_on:
      - elasticsearch
    volumes:
      - kibana_data:/usr/share/kibana/data
      - elasticsearch_certs:/usr/share/kibana/config/certs:ro
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE

  # Nginx Web Interface
  nginx:
    container_name: nginx
    image: dtagdevsec/nginx:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    ports:
      - "{{ ansible_default_ipv4.address }}:64297:64297"
    volumes:
      - nginx_conf:/etc/nginx/conf.d
      - nginx_cert:{{ tpot_data_dir }}/nginx/cert
      - nginx_logs:/var/log/nginx
    environment:
      - NGINX_WEB_USER=${NGINX_WEB_USER:-admin}
      - NGINX_WEB_PW=${NGINX_WEB_PW}
    depends_on:
      - kibana

  # Logstash
  logstash:
    container_name: logstash
    image: dtagdevsec/logstash:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    volumes:
      - logstash_data:/usr/share/logstash/data
      - logstash_conf:/usr/share/logstash/pipeline
    environment:
      - "LS_JAVA_OPTS=-Xmx512m -Xms512m"
    depends_on:
      - elasticsearch

  # EWS Poster (data collection)
  ewsposter:
    container_name: ewsposter
    image: dtagdevsec/ewsposter:{{ tpot_version }}
    restart: unless-stopped
    networks:
      - tpot_local
    volumes:
      - ewsposter_data:/opt/ewsposter/ews
    environment:
      - EWS_HPFEEDS_ENABLE=false
      - EWS_HPFEEDS_HOST=
      - EWS_HPFEEDS_PORT=10000
      - EWS_HPFEEDS_CHANNELS=
      - EWS_HPFEEDS_IDENT=
      - EWS_HPFEEDS_SECRET=
    depends_on:
      - elasticsearch

networks:
  tpot_local:
    driver: bridge
    ipam:
      config:
        - subnet: 172.30.0.0/16

volumes:
  cowrie_data:
  cowrie_keys:
  dionaea_data:
  honeytrap_data:
  mailoney_data:
  suricata_data:
  suricata_rules:
  elasticsearch_data:
  elasticsearch_certs:
  kibana_data:
  logstash_data:
  logstash_conf:
  nginx_conf:
  nginx_cert:
  nginx_logs:
  ewsposter_data:
