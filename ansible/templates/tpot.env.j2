# T-Pot Environment Configuration
# Generated by Ansible - Darkspace Tools
# Honeypot services bind to target IP: {{ target_ip }}

# Host Configuration
HOST_IP={{ target_ip }}
TPOT_HIVE_IP={{ target_ip }}
TPOT_HIVE_USER=hiveuser
TPOT_HIVE_PW={{ tpot_hive_password }}

# Elasticsearch Configuration
ELASTIC_PASSWORD={{ elastic_password }}

# T-Pot Version
TPOT_VERSION={{ tpot_version }}
TPOT_REPO=dtagdevsec
TPOT_TAG={{ tpot_version }}
TPOT_IMAGE_TAG={{ tpot_version }}

# T-Pot Type
TPOT_TYPE=SENSOR
TPOT_FLAVOR=STANDARD

# Docker Configuration
COMPOSE_PROJECT_NAME=tpotce
RESTART_POLICY=unless-stopped
TPOT_PULL_POLICY=if_not_present

# Web Interface
NGINX_WEB_USER=admin
NGINX_WEB_PW={{ tpot_web_password }}

# Network - Bind only to target IP for honeypots, management IP for admin
TPOT_BIND_IP={{ target_ip }}
MANAGEMENT_IP={{ ansible_default_ipv4.address }}

# Data Paths
TPOT_DATA_PATH={{ tpot_data_dir }}
TPOT_DOCKER_COMPOSE={{ tpot_dir }}/docker-compose.yml

# Logging
LOG_LEVEL=INFO
SYSLOG_ENABLED=false

# Security
SSL_ENABLED=true
SSL_CERT_PATH={{ tpot_data_dir }}/nginx/cert/nginx.crt
SSL_KEY_PATH={{ tpot_data_dir }}/nginx/cert/nginx.key

# Elasticsearch
ES_HEAP_SIZE=1g
ES_MEMORY_LOCK=false

# Kibana (management IP only)
KIBANA_HOST={{ ansible_default_ipv4.address }}
KIBANA_PORT=64296

# Nginx (management IP only)
NGINX_HOST={{ ansible_default_ipv4.address }}
NGINX_PORT=64297

# Honeypot Services
COWRIE_ENABLED=true
DIONAEA_ENABLED=true
HONEYTRAP_ENABLED=true
SURICATA_ENABLED=true
MAILONEY_ENABLED=true

# Network Interface Binding
HONEYPOT_BIND_IP={{ target_ip }}
MANAGEMENT_BIND_IP={{ ansible_default_ipv4.address }}

# Timezone
TZ=UTC

# Security
FAIL2BAN_ENABLED=true
UFW_ENABLED=true

# Docker Logging
DOCKER_LOG_DRIVER=json-file
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
